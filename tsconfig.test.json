{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"rootDir": ".",
		"lib": ["DOM", "ES2020"],
		"types": ["node"],
		"composite": true,
		"declaration": true,
		"emitDeclarationOnly": true,
		"outDir": "./.tsbuild/test",
		"tsBuildInfoFile": "./.tsbuild/tsconfig.test.tsbuildinfo"
	},
	"include": ["src/**/*.ts", "tests/**/*.ts"],
	"exclude": ["dist", ".tsbuild", "node_modules"]
}
