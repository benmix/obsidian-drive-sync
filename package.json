{
	"name": "obsidian-drive-sync-plugin",
	"version": "1.0.0",
	"description": "This is a sample plugin for Obsidian (https://obsidian.md)",
	"keywords": [],
	"license": "MIT",
	"type": "module",
	"main": "main.js",
	"scripts": {
		"build": "tsc -noEmit -skipLibCheck && vite build --mode production && node scripts/copy-obsidian-assets.mjs",
		"copy:assets": "node scripts/copy-obsidian-assets.mjs",
		"dev": "node scripts/copy-obsidian-assets.mjs && vite build --watch --mode development",
		"fix:imports": "node scripts/fix-sort-imports.mjs",
		"format": "oxfmt --config .oxfmtrc.json . --write",
		"link:obsidian": "node scripts/link-obsidian-plugin.mjs",
		"lint": "oxfmt --config .oxfmtrc.json --check . && oxlint --config .oxlintrc.json . && pnpm run lint:layers",
		"lint-staged": "lint-staged",
		"lint:fix": "oxfmt --config .oxfmtrc.json . --write && oxlint --config .oxlintrc.json --fix --fix-suggestions .",
		"lint:layers": "node scripts/check-layers.mjs",
		"prepare": "husky install",
		"test": "vitest run",
		"test:unit": "vitest run tests/sync",
		"test:watch": "vitest",
		"version": "node scripts/version-bump.mjs && git add manifest.json versions.json"
	},
	"dependencies": {
		"@protontech/drive-sdk": "latest",
		"bcryptjs": "^3.0.3",
		"dexie": "^4.2.1",
		"mime-types": "^3.0.2",
		"obsidian": "latest",
		"openpgp": "^6.3.0"
	},
	"devDependencies": {
		"@types/mime-types": "^3.0.1",
		"@types/node": "^25.0.9",
		"husky": "^9.1.7",
		"lint-staged": "^16.2.7",
		"oxfmt": "^0.24.0",
		"oxlint": "^1.39.0",
		"tslib": "2.8.1",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^4.0.18"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx,mjs,cjs,json,md}": [
			"oxlint --config .oxlintrc.json --fix",
			"oxfmt"
		]
	},
	"packageManager": "pnpm@10.13.1"
}
