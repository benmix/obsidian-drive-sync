{
	"$schema": "./node_modules/oxlint/configuration_schema.json",
	"plugins": ["typescript", "unicorn"],
	"ignorePatterns": [
		".test-dist",
		"example_repo",
		"node_modules",
		"dist",
		"vite.config.ts",
		"eslint.config.js",
		"version-bump.mjs",
		"versions.json",
		"main.js"
	],
	"env": {
		"browser": true
	},
	"rules": {
		"unicorn/no-useless-fallback-in-spread": "off",
		"sort-imports": [
			"error",
			{
				"allowSeparatedGroups": true,
				"ignoreCase": true
			}
		]
	}
}
